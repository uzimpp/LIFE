# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=life-backend
APP_VERSION=0.1.0

# ── HTTP ──────────────────────────────────────────────────────────────────────
HTTP_PORT=8080
HTTP_HOST=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
# sslmode=disable locally, sslmode=require in production
PG_URL=postgres://postgres:postgres@localhost:5432/life?sslmode=disable
PG_POOL_MAX=10

# ── Logging ───────────────────────────────────────────────────────────────────
# Levels: debug | info | warn | error
LOG_LEVEL=info

# ── Swagger ───────────────────────────────────────────────────────────────────
# Keep false in production
SWAGGER_ENABLED=true

# ── Google OAuth2 ─────────────────────────────────────────────────────────────
OAUTH_CLIENT_ID=your-google-client-id
OAUTH_CLIENT_SECRET=your-google-client-secret
OAUTH_REDIRECT_URL=http://localhost:8080/v1/auth/google/callback

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_COOKIE_NAME=session
SESSION_TTL=720h
SESSION_DOMAIN=
SESSION_SECURE=false

# ── Docker Compose only (NOT read by the Go app) ─────────────────────────────
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=life
